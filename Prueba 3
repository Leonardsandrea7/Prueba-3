<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Panel SMM TikTok</title>
  <style>
    body {
      font-family: sans-serif;
      padding: 20px;
      background: #f8f8f8;
      max-width: 500px;
      margin: auto;
    }
    h1 {
      text-align: center;
      color: #111;
    }
    label {
      display: block;
      margin-top: 15px;
      font-weight: bold;
    }
    input, select, button {
      width: 100%;
      padding: 12px;
      margin-top: 8px;
      border-radius: 8px;
      border: 1px solid #ccc;
      font-size: 16px;
    }
    button {
      background-color: #1e90ff;
      color: white;
      margin-top: 20px;
      border: none;
      cursor: pointer;
    }
    .response {
      margin-top: 20px;
      text-align: center;
      font-weight: bold;
      color: green;
    }
  </style>
</head>
<body>
  <h1>Panel TikTok SMM</h1>
  <label for="video">Enlace del Video TikTok:</label>
  <input type="text" id="video" placeholder="https://www.tiktok.com/..." />

  <label for="cantidad">Cantidad de Donaciones:</label>
  <input type="number" id="cantidad" min="1" max="10000" value="100" />

  <button onclick="enviarDonacion()">Enviar</button>

  <div class="response" id="respuesta"></div>

  <script>
    function enviarDonacion() {
      const video = document.getElementById('video').value;
      const cantidad = document.getElementById('cantidad').value;

      if (!video || !cantidad) {
        document.getElementById('respuesta').innerText = 'Por favor completa todos los campos.';
        return;
      }

      document.getElementById('respuesta').innerText = `Se han enviado ${cantidad} donaciones al video:\n${video}`;
    }
  </script>
</body>
</html>
